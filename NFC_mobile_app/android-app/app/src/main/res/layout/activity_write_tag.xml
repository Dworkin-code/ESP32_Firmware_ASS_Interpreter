<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:id="@+id/write_summary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="A backup will be saved before writing. Hold the tag to the phone when you tap Write."
            android:layout_marginTop="8dp" />
        <Button android:id="@+id/btn_confirm_write"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Write to tag"
            android:layout_marginTop="24dp" />
        <TextView android:id="@+id/write_result"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
