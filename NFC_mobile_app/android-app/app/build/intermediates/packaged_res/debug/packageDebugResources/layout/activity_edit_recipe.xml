<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recipe header" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ID (0–255)" />
        <EditText android:id="@+id/edit_id" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:maxLength="3" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Number of drinks" />
        <EditText android:id="@+id/edit_num_drinks" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recipe steps (count)" />
        <EditText android:id="@+id/edit_recipe_steps" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Actual recipe step (0-based index of next step to execute)" />
        <EditText android:id="@+id/edit_actual_recipe_step" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Actual budget" />
        <EditText android:id="@+id/edit_budget" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Parameters (0–255)" />
        <EditText android:id="@+id/edit_parameters" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="number" android:maxLength="3" />
        <CheckBox android:id="@+id/edit_recipe_done"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recipe done" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="RightNumber (read-only, auto: 255 − ID)" android:textStyle="italic" android:layout_marginTop="8dp" />
        <TextView android:id="@+id/right_number_display" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:enabled="false" android:focusable="false" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CheckSum (read-only, auto from step bytes)" android:textStyle="italic" />
        <TextView android:id="@+id/checksum_display" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:enabled="false" android:focusable="false" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Steps" android:textStyle="bold" android:layout_marginTop="16dp" />
        <LinearLayout android:id="@+id/step_editors_container"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginTop="4dp" />

        <Button android:id="@+id/btn_done_edit"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Done – proceed to write"
            android:layout_marginTop="24dp" />
    </LinearLayout>
</ScrollView>
