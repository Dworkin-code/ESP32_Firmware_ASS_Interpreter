<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:id="@+id/write_summary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" />
        <TextView android:id="@+id/write_capacity"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />
        <TextView android:id="@+id/write_capacity_warning"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark" />
        <TextView
            android:id="@+id/write_identity_debug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/write_identity_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="12sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1) Scan tag, then put it away. 2) Edit recipe if needed. 3) Tap Write to tag – the app will wait. 4) When ready, hold the tag to the back of the phone to write."
            android:layout_marginTop="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Preview (verify before write)"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />
        <TextView android:id="@+id/write_preview"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:minLines="8"
            android:scrollbars="vertical"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />
        <Button android:id="@+id/btn_confirm_write"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Write to tag"
            android:layout_marginTop="24dp" />
        <TextView android:id="@+id/write_result"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
